# Configurações do Servidor
PORT=3005
JWT_SECRET=sua_secret_jwt_aqui_gerada_aleatoriamente
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Segurança (CRITICAL)
# Chave de 32 caracteres para criptografia AES-256 das chaves S3 no banco
MASTER_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_mysql
DB_NAME=storage_manager

# Integração com Optimizer
# URL interna do container ou localhost para comunicação backend-optimizer
OPTIMIZER_URL=http://optimizer:8000
# URL pública do optimizer (usada pelo MinIO para enviar Webhooks)
PUBLIC_OPTIMIZER_URL=http://seu-dominio.com:8009/minio-webhook

# Callback para o Optimizer avisar o backend
PUBLIC_BACKEND_URL=http://localhost:3005
