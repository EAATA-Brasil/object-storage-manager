# Configurações do Manager (Integração)
# URL do backend para o Optimizer buscar configurações dinâmicas
MANAGER_BASE_URL=http://backend:3005
DEFAULT_STORAGE_ID=default

# Configurações do MinIO (Fallback se não usar o Manager)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=senha_admin
MINIO_SECURE=false
MINIO_BUCKET=bucket-padrao

# Performance
MAX_CONCURRENCY=2
BATCH_SLEEP_MS=0

# Otimização de Imagem
IMG_MAX_WIDTH=1600
IMG_QUALITY_JPEG=78
IMG_QUALITY_WEBP=72

# Otimização de Vídeo
VIDEO_MAX_WIDTH=1280
VIDEO_CRF=28
VIDEO_PRESET=veryfast
AUDIO_BITRATE=96k
